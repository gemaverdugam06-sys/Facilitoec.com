# Supabase (client — safe to expose in browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key

# Optional alias (use same value as publishable key)
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Public app URLs (client)
VITE_PAYPHONE_LINK=https://payp.page/l/FacilitoEC
VITE_OG_IMAGE_URL=https://your-domain.com/og-image.png

# Server-only (never prefix with VITE_)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Auth: enable Phone provider + SMS (Twilio/MessageBird) in dashboard.
# Add redirect URLs:
#   https://your-domain.com/auth/nueva-contrasena
#   http://localhost:5173/auth/nueva-contrasena

# Admin: assign role manually in Supabase SQL Editor after first signup:
#   INSERT INTO public.user_roles (user_id, role)
#   SELECT id, 'admin'::app_role FROM auth.users
#   WHERE lower(email) = lower('tu-email@ejemplo.com')
#   ON CONFLICT (user_id, role) DO NOTHING;
